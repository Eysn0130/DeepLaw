{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Eysn0130/DeepLaw/contracts/catalog-trust.v1.schema.json",
  "title": "DeepLaw Official Catalog Trust Store v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "keys"],
  "properties": {
    "schemaVersion": {
      "const": "deeplaw.catalog-trust/v1"
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "algorithm", "publicKey", "status"],
        "properties": {
          "keyId": {
            "type": "string",
            "pattern": "^ed25519:[0-9a-f]{64}$"
          },
          "algorithm": {
            "const": "Ed25519"
          },
          "publicKey": {
            "type": "string",
            "contentEncoding": "base64"
          },
          "status": {
            "enum": ["active", "revoked"]
          }
        }
      }
    }
  }
}
