{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:deeplaw:schema:review-overlay:v1",
  "title": "DeepLawReviewOverlayV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "package", "documents"],
  "properties": {
    "schemaVersion": { "const": "deeplaw.review-overlay/v1" },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewedAsOf",
        "reviewerKind",
        "reviewScope",
        "temporalStatus",
        "redistributionStatus"
      ],
      "properties": {
        "reviewedAsOf": { "type": "string", "format": "date" },
        "reviewerKind": { "enum": ["ai_precheck", "human", "mixed"] },
        "reviewScope": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "temporalStatus": {
          "enum": ["requires_human_review", "partially_verified", "verified"]
        },
        "redistributionStatus": {
          "enum": ["not_assessed", "approved", "restricted"]
        }
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/documentReview" }
    }
  },
  "$defs": {
    "dateOrNull": {
      "type": ["string", "null"],
      "format": "date"
    },
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "maxLength": 2048
    },
    "reviewState": {
      "enum": ["unreviewed", "ai_prechecked", "human_reviewed", "not_applicable"]
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "targetSourceSha256", "reviewStatus", "evidenceUrl"],
      "properties": {
        "predicate": {
          "enum": ["cites", "amends", "repeals", "replaces", "implements", "exception_to"]
        },
        "targetSourceSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "validFrom": { "$ref": "#/$defs/dateOrNull" },
        "validTo": { "$ref": "#/$defs/dateOrNull" },
        "reviewStatus": { "enum": ["ai_prechecked", "human_reviewed"] },
        "evidenceUrl": { "$ref": "#/$defs/httpsUrl" }
      }
    },
    "documentReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceSha256",
        "path",
        "title",
        "status",
        "documentType",
        "issuer",
        "authorityRank",
        "canonicalAuthorityUrl",
        "retrievalSourceUrl",
        "sourceReviewStatus",
        "temporalReviewStatus",
        "extractionReviewStatus",
        "redistributionStatus",
        "statusAsOf",
        "evidenceUrls",
        "relations"
      ],
      "properties": {
        "sourceSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "documentNumber": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
        "aliases": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "promulgatedOn": { "$ref": "#/$defs/dateOrNull" },
        "effectiveDate": { "$ref": "#/$defs/dateOrNull" },
        "effectiveTo": { "$ref": "#/$defs/dateOrNull" },
        "status": {
          "enum": [
            "unknown",
            "unverified_current",
            "verified_current",
            "verified_historical",
            "not_yet_effective",
            "repealed",
            "superseded"
          ]
        },
        "documentType": {
          "enum": [
            "law",
            "administrative_regulation",
            "judicial_interpretation",
            "prosecution_standard",
            "departmental_rule",
            "normative_document",
            "case_reference"
          ]
        },
        "issuer": { "type": "string", "minLength": 1, "maxLength": 200 },
        "authorityRank": { "type": "integer", "minimum": 0, "maximum": 100 },
        "canonicalAuthorityUrl": {
          "oneOf": [
            { "$ref": "#/$defs/httpsUrl" },
            { "type": "null" }
          ]
        },
        "retrievalSourceUrl": { "$ref": "#/$defs/httpsUrl" },
        "sourceReviewStatus": { "$ref": "#/$defs/reviewState" },
        "temporalReviewStatus": { "$ref": "#/$defs/reviewState" },
        "extractionReviewStatus": { "$ref": "#/$defs/reviewState" },
        "redistributionStatus": {
          "enum": ["not_assessed", "approved", "restricted"]
        },
        "statusAsOf": { "type": "string", "format": "date" },
        "evidenceUrls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/httpsUrl" }
        },
        "relations": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/relation" }
        },
        "note": { "type": ["string", "null"], "maxLength": 4000 }
      }
    }
  }
}
