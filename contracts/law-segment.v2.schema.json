{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:deeplaw:schema:law-segment:v2",
  "title": "DeepLawSegmentV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "receipt_id",
    "segment_id",
    "document_id",
    "title",
    "document_number",
    "jurisdiction",
    "promulgated_on",
    "document_type",
    "issuer",
    "authority_rank",
    "official_source",
    "source_sha256",
    "segment_sha256",
    "ordinal",
    "kind",
    "part_index",
    "text",
    "truncated",
    "status",
    "temporal_review_required",
    "temporal_metadata_verified",
    "extraction_method",
    "extraction_configuration",
    "extraction_review_required",
    "extraction_warnings"
  ],
  "properties": {
    "schema_version": { "const": "deeplaw.segment/v2" },
    "release_id": { "type": "string", "pattern": "^lawrel_[0-9a-f]{32}$" },
    "receipt_id": { "type": "string", "pattern": "^lawrcpt_[0-9a-f]{32}$" },
    "segment_id": { "type": "string", "pattern": "^seg_[0-9a-f]{24}$" },
    "document_id": { "type": "string", "pattern": "^doc_[0-9a-f]{24}$" },
    "title": { "type": "string", "maxLength": 500 },
    "document_number": { "type": ["string", "null"], "maxLength": 200 },
    "jurisdiction": { "type": "string", "maxLength": 64 },
    "promulgated_on": { "type": ["string", "null"], "format": "date" },
    "document_type": { "type": "string", "maxLength": 64 },
    "issuer": { "type": "string", "maxLength": 200 },
    "authority_rank": { "type": "integer", "minimum": 0, "maximum": 100 },
    "official_source": { "type": "string", "format": "uri", "maxLength": 2048 },
    "source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "segment_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "ordinal": { "type": "integer", "minimum": 1 },
    "kind": { "type": "string", "maxLength": 64 },
    "heading": { "type": ["string", "null"], "maxLength": 500 },
    "article_label": { "type": ["string", "null"], "maxLength": 100 },
    "part_index": { "type": "integer", "minimum": 1 },
    "page_start": { "type": ["integer", "null"], "minimum": 1 },
    "page_end": { "type": ["integer", "null"], "minimum": 1 },
    "paragraph_start": { "type": ["integer", "null"], "minimum": 1 },
    "paragraph_end": { "type": ["integer", "null"], "minimum": 1 },
    "text": { "type": "string", "maxLength": 12000 },
    "truncated": { "type": "boolean" },
    "effective_from": { "type": ["string", "null"], "format": "date" },
    "effective_to": { "type": ["string", "null"], "format": "date" },
    "status": {
      "enum": [
        "unknown",
        "unverified_current",
        "verified_current",
        "verified_historical",
        "not_yet_effective",
        "repealed",
        "superseded"
      ]
    },
    "temporal_review_required": { "type": "boolean" },
    "temporal_metadata_verified": { "type": "boolean" },
    "extraction_method": { "type": "string", "maxLength": 100 },
    "extraction_version": { "type": ["string", "null"], "maxLength": 500 },
    "extraction_configuration": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "maxLength": 200 }
    },
    "extraction_review_required": { "type": "boolean" },
    "extraction_warnings": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "maxLength": 1000 }
    }
  }
}
